# Cognito hosted-UI domain (no protocol), e.g. my-pool.auth.ap-southeast-1.amazoncognito.com
VITE_COGNITO_DOMAIN=
# Cognito App Client id (public SPA client, no secret).
VITE_COGNITO_CLIENT_ID=
# Base URL of the backend API (the connectors + toolkits endpoints live here).
VITE_BACKEND_URL=
# Set to "true" to serve the API from the in-browser msw mock during `npm run dev`.
VITE_ENABLE_MOCKS=false
